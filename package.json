{
  "name": "omnisockit-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "OmniSocKit — 让你的 AI 大模型成为社交营销平台开发专家",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
